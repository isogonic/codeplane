<?xml version="1.0" encoding="utf-8"?>
<!--
  Drop into android/app/src/main/res/xml/network_security_config.xml
  and reference it from AndroidManifest.xml's <application> via
    android:networkSecurityConfig="@xml/network_security_config"

  Default config disallows cleartext (http://) traffic. The
  per-instance trust override is intentionally not implemented at
  the manifest level — code that builds the WebView client wires the
  override at runtime so untrusted certificates only apply to the one
  instance the user opted into.
-->
<network-security-config>
  <base-config cleartextTrafficPermitted="false">
    <trust-anchors>
      <certificates src="system" />
      <certificates src="user" />
    </trust-anchors>
  </base-config>
</network-security-config>
