{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@codeplane-ai/desktop",
  "private": true,
  "version": "31.1.0",
  "productName": "Codeplane",
  "description": "Codeplane Desktop connects to remote Codeplane servers and caches the matching UI locally for fast native use.",
  "license": "MIT",
  "homepage": "https://codeplane.cc",
  "repository": {
    "type": "git",
    "url": "https://github.com/devinoldenburg/codeplane.git"
  },
  "bugs": {
    "url": "https://github.com/devinoldenburg/codeplane/issues"
  },
  "author": {
    "name": "Devin Oldenburg",
    "email": "devin@logicplanes.com",
    "url": "https://github.com/devinoldenburg"
  },
  "main": "dist/main/main.cjs",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist release && bun run build:main && bun run build:setup",
    "build:icons": "bun ./build/generate-icons.ts",
    "build:main": "bun build src/main/main.ts src/main/preload.ts --outdir dist/main --target node --external electron --format cjs --minify && mv dist/main/main.js dist/main/main.cjs && mv dist/main/preload.js dist/main/preload.cjs",
    "build:setup": "vite build",
    "dev:setup": "vite",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "publish": "electron-builder --publish always",
    "dev": "bun run build && electron .",
    "typecheck": "tsgo --noEmit",
    "test:e2e": "bun run build && playwright test",
    "test:e2e:ui": "bun run build && playwright test --ui",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "dependencies": {},
  "devDependencies": {
    "@codeplane-ai/shared": "file:../shared",
    "@codeplane-ai/ui": "file:../ui",
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "4.1.11",
    "@types/node": "22.13.9",
    "@typescript/native-preview": "7.0.0-dev.20251207.1",
    "dompurify": "catalog:",
    "electron": "41.4.0",
    "electron-builder": "26.8.1",
    "electron-store": "10.1.0",
    "electron-updater": "6.6.8",
    "marked": "catalog:",
    "solid-js": "1.9.10",
    "tailwindcss": "4.1.11",
    "typescript": "5.8.2",
    "vite": "7.3.2",
    "vite-plugin-solid": "2.11.10"
  },
  "build": {
    "appId": "cc.codeplane.desktop",
    "productName": "Codeplane",
    "executableName": "Codeplane",
    "copyright": "Copyright © 2026 Devin Oldenburg",
    "asar": true,
    "beforeBuild": "./build/before-build.js",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "build/icon.png",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/main.cjs",
      "type": "commonjs"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "devinoldenburg",
        "repo": "codeplane",
        "releaseType": "release"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "executableName": "Codeplane",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "darkModeSupport": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "CFBundleGetInfoString": "Codeplane Desktop",
        "CFBundleSpokenName": "Codeplane",
        "NSHumanReadableCopyright": "Copyright © 2026 Devin Oldenburg",
        "NSAccessibilityUsageDescription": "Codeplane needs Accessibility access to move the cursor, click, type, and send keyboard shortcuts when Computer Use is enabled.",
        "NSScreenCaptureUsageDescription": "Codeplane captures the screen so Computer Use can see what the agent is operating on.",
        "NSCameraUsageDescription": "Codeplane does not use the camera. This entry exists so embedded web content (e.g. a connected app's video call) can request access explicitly.",
        "NSMicrophoneUsageDescription": "Codeplane does not use the microphone. This entry exists so embedded web content (e.g. a connected app's voice call) can request access explicitly.",
        "NSDesktopFolderUsageDescription": "Codeplane may read files you drag in from your Desktop folder.",
        "NSDocumentsFolderUsageDescription": "Codeplane may read files you drag in from your Documents folder.",
        "NSDownloadsFolderUsageDescription": "Codeplane may read files you drag in from your Downloads folder."
      },
      "artifactName": "codeplane-desktop-${version}-mac-${arch}.${ext}"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "background": "build/dmg-background.png",
      "icon": "build/icon.icns",
      "iconSize": 96,
      "iconTextSize": 12,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 200,
          "type": "file"
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "executableName": "Codeplane",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "codeplane-desktop-${version}-win-${arch}.${ext}"
    },
    "linux": {
      "executableName": "codeplane",
      "synopsis": "Native desktop shell for remote Codeplane servers",
      "description": "Codeplane Desktop connects to remote Codeplane servers, downloads the matching web UI for each server version, and reuses cached UI bundles locally for faster launches and switching.",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Development",
      "maintainer": "Devin Oldenburg <devin@logicplanes.com>",
      "desktop": {
        "entry": {
          "Name": "Codeplane",
          "GenericName": "AI development desktop app",
          "Comment": "Connect to remote Codeplane servers with a native desktop shell",
          "StartupWMClass": "Codeplane",
          "X-GNOME-FullName": "Codeplane Desktop"
        }
      },
      "artifactName": "codeplane-desktop-${version}-linux-${arch}.${ext}"
    },
    "deb": {
      "afterInstall": "build/after-install.sh",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0",
        "libdrm2",
        "libgbm1",
        "libxcb-dri3-0",
        "libasound2"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "shortcutName": "Codeplane",
      "uninstallDisplayName": "Codeplane"
    }
  }
}
