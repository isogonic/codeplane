{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "paths": {
      "@codeplane-ai/ui/*": ["../ui/src/components/*.tsx"],
      "@codeplane-ai/ui/styles/tailwind": ["../ui/src/styles/tailwind/index.css"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
