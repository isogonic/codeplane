{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "codeplane",
  "description": "AI-powered development tool",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun --cwd packages/app dev",
    "dev:server": "bun run --cwd packages/codeplane --conditions=browser src/index.ts web --instance dev",
    "dev:web": "bun --cwd packages/app dev",
    "dev:instance": "bun run --cwd packages/codeplane --conditions=browser script/dev-instance.ts",
    "version:sync": "bun script/sync-version.ts",
    "version:bump": "bun script/bump-version.ts",
    "lint": "oxlint",
    "typecheck": "bun turbo typecheck",
    "postinstall": "bun run --cwd packages/codeplane fix-node-pty",
    "prepare": "husky",
    "test": "echo 'do not run tests from root' && exit 1"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/sdk/js"
    ],
    "catalog": {
      "@effect/opentelemetry": "4.0.0-beta.48",
      "@effect/platform-node": "4.0.0-beta.48",
      "@npmcli/arborist": "9.4.0",
      "@types/bun": "1.3.12",
      "@types/cross-spawn": "6.0.6",
      "@octokit/rest": "22.0.0",
      "@hono/zod-validator": "0.4.2",
      "ulid": "3.0.1",
      "@kobalte/core": "0.13.11",
      "@types/luxon": "3.7.1",
      "@types/node": "22.13.9",
      "@types/semver": "7.7.1",
      "@tsconfig/node22": "22.0.2",
      "@tsconfig/bun": "1.0.9",
      "@cloudflare/workers-types": "4.20251008.0",
      "@openauthjs/openauth": "0.0.0-20250322224806",
      "@pierre/diffs": "1.1.0-beta.18",
      "@solid-primitives/storage": "4.3.3",
      "@tailwindcss/vite": "4.1.11",
      "diff": "8.0.4",
      "dompurify": "3.4.2",
      "drizzle-kit": "1.0.0-beta.19-d95b7a4",
      "drizzle-orm": "1.0.0-beta.19-d95b7a4",
      "effect": "4.0.0-beta.48",
      "ai": "6.0.168",
      "cross-spawn": "7.0.6",
      "hono": "4.12.16",
      "hono-openapi": "1.1.2",
      "fuzzysort": "3.1.0",
      "luxon": "3.6.1",
      "marked": "17.0.1",
      "marked-shiki": "1.2.1",
      "remend": "1.3.0",
      "@playwright/test": "1.59.1",
      "semver": "7.7.4",
      "typescript": "5.8.2",
      "@typescript/native-preview": "7.0.0-dev.20251207.1",
      "zod": "4.1.8",
      "remeda": "2.26.0",
      "shiki": "3.20.0",
      "solid-list": "0.3.0",
      "tailwindcss": "4.1.11",
      "virtua": "0.42.3",
      "vite": "7.3.2",
      "@solidjs/meta": "0.29.4",
      "@solidjs/router": "0.15.4",
      "@solidjs/start": "https://pkg.pr.new/@solidjs/start@dfb2020",
      "solid-js": "1.9.10",
      "vite-plugin-solid": "2.11.10",
      "@lydell/node-pty": "1.2.0-beta.10"
    }
  },
  "devDependencies": {
    "@actions/artifact": "6.2.1",
    "@tsconfig/bun": "1.0.9",
    "@types/mime-types": "3.0.1",
    "@typescript/native-preview": "7.0.0-dev.20251207.1",
    "glob": "13.0.5",
    "husky": "9.1.7",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.0",
    "prettier": "3.6.2",
    "semver": "^7.6.0",
    "sst": "4.12.11",
    "turbo": "2.8.13"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1041.0",
    "@codeplane-ai/plugin": "file:packages/plugin",
    "@codeplane-ai/script": "file:packages/script",
    "@codeplane-ai/sdk": "file:packages/sdk/js",
    "codeplane-ai": "^27.3.1",
    "heap-snapshot-toolkit": "1.1.3",
    "typescript": "5.8.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/isogonic/codeplane"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "trustedDependencies": [
    "esbuild",
    "node-pty",
    "protobufjs",
    "tree-sitter",
    "tree-sitter-bash",
    "tree-sitter-powershell",
    "web-tree-sitter"
  ],
  "overrides": {
    "@types/bun": "1.3.12",
    "@types/node": "22.13.9",
    "vite": "7.3.2",
    "undici": "6.25.0",
    "@remix-run/router": "1.23.2",
    "react-router": "7.14.2",
    "react-router-dom": "7.14.2",
    "yaml": "2.8.4",
    "esbuild": "0.25.10",
    "fast-xml-parser": "5.7.2",
    "h3": "2.0.1-rc.21",
    "srvx": "0.11.15",
    "uuid": "14.0.0",
    "seroval": "1.5.2",
    "seroval-plugins": "1.5.2",
    "postcss": "8.5.10",
    "dompurify": "3.4.2",
    "protobufjs": "7.5.6"
  },
  "patchedDependencies": {
    "@npmcli/agent@4.0.0": "patches/@npmcli%2Fagent@4.0.0.patch",
    "@standard-community/standard-openapi@0.2.9": "patches/@standard-community%2Fstandard-openapi@0.2.9.patch",
    "solid-js@1.9.10": "patches/solid-js@1.9.10.patch"
  }
}
